@using Microsoft.AspNetCore.Http;

@model inter.Models.Pessoas

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>

    <title>Meu Perfil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
        style="background-color:#F15A24;">

        <div class="container-fluid">

            <span class="navbar-brand fw-bold fs-3">
                JOGAL
            </span>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid">

        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-2 p-0">

                <div class="bg-dark text-white vh-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-2">

                            <a href="/Catalogo"
                            class="nav-link text-white">

                                Catálogo

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Historico"
                            class="nav-link text-white">

                                Meus Pedidos

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Perfil"
                            class="nav-link text-white fw-bold">

                                Meu Perfil

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">
        

        <div class="container mt-5">

            <div class="card border-0 shadow">

                <div class="card-body p-5">

                    <h2 class="fw-bold mb-4">

                        Meu Perfil

                    </h2>

                    @if(TempData["Sucesso"] != null)
                    {
                        <div class="alert alert-success">

                            @TempData["Sucesso"]

                        </div>
                    }

                    <form method="post" id="formPerfil">

                        <div class="mb-3">

                            <label class="form-label">

                                Email

                            </label>

                            <input type="email"
                                name="Email"
                                value="@Model.Email"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Nova Senha

                            </label>

                            <input type="text"
                                name="Senha"
                                value="@Model.Senha"
                                class="form-control"
                                required>

                        </div>

                        <button type="button"
                                class="btn text-white fw-bold"
                                style="background-color:#F15A24;"
                                data-bs-toggle="modal"
                                data-bs-target="#modalSalvar">

                            Salvar

                        </button>

                        <a href="/Catalogo"
                        class="btn btn-dark fw-bold ms-2">

                            Voltar

                        </a>

                    </form>

                </div>

            </div>

        </div>

        <!-- MODAL -->
        <div class="modal fade"
            id="modalSalvar"
            tabindex="-1">

            <div class="modal-dialog modal-dialog-centered">

                <div class="modal-content border-0 shadow">

                    <div class="modal-header"
                        style="background-color:#F15A24;">

                        <h5 class="modal-title text-white fw-bold">

                            Confirmar Alteração

                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        Deseja realmente alterar seus dados?

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">

                            Cancelar

                        </button>

                        <button type="submit"
                                form="formPerfil"
                                class="btn btn-success">

                            Confirmar

                        </button>

                    </div>

                </div>

            </div>

        </div>
        
    </div>

</body>

</html>