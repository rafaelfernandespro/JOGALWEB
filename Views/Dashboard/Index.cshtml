
@using Microsoft.AspNetCore.Http;

@model inter.Models.ViewModels.DashboardViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>

    <title>Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <!-- NAVBAR SUPERIOR -->
    <nav class="navbar navbar-dark shadow"
        style="background-color:#F15A24;">

        <div class="container-fluid">

            <span class="navbar-brand fw-bold fs-3">
                JOGAL
            </span>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid">

        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-2 p-0">

                <div class="bg-dark text-white vh-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-2">

                            <a href="/Dashboard"
                               class="nav-link text-white">

                                Dashboard

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Produtos"
                               class="nav-link text-white">

                                Estoque

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Pedidos"
                               class="nav-link text-white">

                                Pedidos

                            </a>

                        </li>


                        <li class="nav-item mb-2">

                            <a href="/Usuarios"
                               class="nav-link text-white">

                                Usuários

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                <h1 class="fw-bold mb-4">
                    Dashboard
                </h1>

                <!-- CARDS -->
                <div class="row">

                    <!-- PRODUTOS -->
                    <div class="col-md-4 mb-4">

                        <div class="card border-0 shadow">

                            <div class="card-body">

                                <h5 class="text-muted">
                                    Produtos
                                </h5>

                                <h1 class="fw-bold">
                                    @Model.TotalProdutos
                                </h1>

                            </div>

                        </div>

                    </div>

                    <!-- PEDIDOS -->
                    <div class="col-md-4 mb-4">

                        <div class="card border-0 shadow">

                            <div class="card-body">

                                <h5 class="text-muted">
                                    Pedidos
                                </h5>

                                <h1 class="fw-bold">
                                    @Model.TotalPedidos
                                </h1>

                            </div>

                        </div>

                    </div>

                    <!-- CLIENTES -->
                    <div class="col-md-4 mb-4">

                        <div class="card border-0 shadow">

                            <div class="card-body">

                                <h5 class="text-muted">
                                    Clientes
                                </h5>

                                <h1 class="fw-bold">
                                    @Model.TotalClientes
                                </h1>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- TABELA -->
                <div class="card border-0 shadow mt-4">

                    <div class="card-body">

                        <h4 class="mb-4">
                            Últimos Pedidos
                        </h4>

                        @if (!Model.UltimosPedidos.Any())
                        {
                            <div class="alert alert-warning">

                                Nenhum pedido encontrado.

                            </div>
                        }
                        else
                        {
                            <table class="table table-hover">

                                <thead>

                                    <tr>

                                        <th>ID</th>
                                        <th>Cliente</th>
                                        <th>Total Itens</th>
                                        <th>Status</th>
                                        <th>Data</th>

                                    </tr>

                                </thead>

                                <tbody>

                                    @foreach(var pedido in Model.UltimosPedidos)
                                    {
                                        <tr>

                                            <td>
                                                @pedido.Id
                                            </td>

                                            <td>
                                                @pedido.ClienteId
                                            </td>

                                            <td>
                                                @(pedido.Itens != null
                                                    ? pedido.Itens.Sum(i => i.Quantidade)
                                                    : 0)
                                            </td>

                                            <td>

                                                @pedido.Status?.Descricao

                                            </td>

                                            <td>

                                                @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")

                                            </td>

                                        </tr>
                                    }

                                </tbody>

                            </table>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>
```
