
@using Microsoft.AspNetCore.Http;

@{
    Layout = null;
}

@model inter.Models.Pessoas

<!DOCTYPE html>
<html>

<head>

    <title>Editar Usuário</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
        style="background-color:#F15A24;">

        <div class="container-fluid">

            <span class="navbar-brand fw-bold fs-3">
                JOGAL
            </span>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid">

        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-2 p-0">

                <div class="bg-dark text-white vh-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                <div class="card border-0 shadow">

                    <div class="card-body p-4">

                        <h2 class="fw-bold mb-4">
                            Editar Usuário
                        </h2>

                        <form method="post">

                            <input type="hidden"
                                   name="Id"
                                   value="@Model.Id">

                            <div class="mb-3">

                                <label class="form-label">
                                    Nome
                                </label>

                                <input type="text"
                                       name="Nome"
                                       value="@Model.Nome"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    CPF
                                </label>

                                <input type="text"
                                       name="Cpf"
                                       value="@Model.Cpf"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Endereço
                                </label>

                                <input type="text"
                                       name="Endereco"
                                       value="@Model.Endereco"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Número
                                </label>

                                <input type="text"
                                       name="Numero"
                                       value="@Model.Numero"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Email
                                </label>

                                <input type="email"
                                       name="Email"
                                       value="@Model.Email"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Senha
                                </label>

                                <input type="text"
                                       name="Senha"
                                       value="@Model.Senha"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-4">

                                <label class="form-label">
                                    Tipo
                                </label>

                                <select name="Tipo"
                                        class="form-select">

                                    @foreach(var tipo in ViewBag.Tipos)
                                    {
                                        if(tipo.Id == Model.Tipo)
                                        {
                                            <option value="@tipo.Id" selected>
                                                @tipo.Descricao
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@tipo.Id">
                                                @tipo.Descricao
                                            </option>
                                        }
                                    }

                                </select>

                            </div>

                            <button type="submit"
                                    class="btn text-white fw-bold"
                                    style="background-color:#F15A24;">

                                Salvar Alterações

                            </button>

                            <a href="/Usuarios"
                               class="btn btn-secondary">

                                Voltar

                            </a>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>