@using Microsoft.AspNetCore.Http;

@{
    Layout = null;
}

@model List<inter.Models.Pessoas>

<!DOCTYPE html>
<html>

<head>

    <title>Usuários</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
        style="background-color:#F15A24;">

        <div class="container-fluid">

            <a class="navbar-brand" href="/Dashboard">

                <img src="/logo/logo.jpg"
                    height="50"
                    class="rounded-4">

            </a>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid p-0">

    <div class="row g-0 align-items-stretch">

        <!-- SIDEBAR -->
        <div class="col-2 p-0">

            <div class="bg-dark text-white min-vh-100 h-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-2">
                            <a href="/Dashboard"
                               class="nav-link text-white">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item mb-2">
                            <a href="/Produtos"
                               class="nav-link text-white">
                                Estoque
                            </a>
                        </li>

                        <li class="nav-item mb-2">
                            <a href="/Pedidos"
                               class="nav-link text-white">
                                Pedidos
                            </a>
                        </li>


                        <li class="nav-item mb-2">
                            <a href="/Usuarios"
                               class="nav-link text-white fw-bold">
                                Usuários
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                <!-- TOPO -->
                <div class="d-flex justify-content-between align-items-center mb-4">

                    <div>

                        <h1 class="fw-bold">
                            Usuários
                        </h1>

                        <p class="text-muted">
                            Gerenciamento de usuários do sistema
                        </p>

                    </div>

                    <a href="/Usuarios/Create"
                       class="btn text-white fw-bold"
                       style="background-color:#F15A24;">

                        Novo Usuário

                    </a>

                </div>

                <!-- PESQUISA -->
                <div class="card border-0 shadow mb-4">

                    <div class="card-body">

                        <div class="row">

                            <div class="col-md-6">

                                <input type="text"
                                       id="pesquisa"
                                       class="form-control"
                                       placeholder="Pesquisar usuário...">

                            </div>

                            @if(Context.Session.GetString("tipo") == "2")
                            {
                                <div class="col-md-3">

                                    <select id="filtroTipo"
                                            class="form-select">

                                        <option value="">
                                            Todos os tipos
                                        </option>

                                        <option value="CLIENTE">
                                            Cliente
                                        </option>

                                        <option value="OPERADOR">
                                            Operador
                                        </option>

                                        <option value="FUNCIONÁRIO">
                                            Funcionário
                                        </option>

                                    </select>

                                </div>
                            }

                        </div>

                    </div>

                </div>

                <!-- TABELA -->
                <div class="card border-0 shadow">

                    <div class="card-body">

                        @if (!Model.Any())
                        {
                            <div class="alert alert-warning">

                                Nenhum usuário cadastrado.

                            </div>
                        }
                        else
                        {
                            <table class="table table-hover align-middle"
                                   id="tabelaUsuarios">

                                <thead>

                                    <tr>

                                        <th>ID</th>
                                        <th>Nome</th>
                                        <th>Email</th>
                                        <th>Tipo</th>
                                        <th>Ações</th>

                                    </tr>

                                </thead>

                                <tbody>

                                    @foreach(var item in Model)
                                    {
                                        string tipo = item.Tipo switch
                                        {
                                            1 => "CLIENTE",
                                            2 => "OPERADOR",
                                            3 => "FUNCIONÁRIO",
                                            _ => "DESCONHECIDO"
                                        };
                                        <tr>

                                            <td>
                                                @item.Id
                                            </td>

                                            <td class="fw-semibold">
                                                @item.Nome
                                            </td>

                                            <td>
                                                @item.Email
                                            </td>

                                            <td class="tipo">
                                                @tipo
                                            </td>

                                            <td>

                                                <a href="/Usuarios/Update/@item.Id"
                                                   class="btn btn-sm btn-warning text-white">

                                                    Editar

                                                </a>

                                                <button class="btn btn-sm btn-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalExcluir_@item.Id">

                                                    Excluir

                                                </button>

                                            </td>

                                        </tr>

                                        <!-- MODAL -->
                                        <div class="modal fade"
                                            id="modalExcluir_@item.Id"
                                            tabindex="-1">

                                            <div class="modal-dialog modal-dialog-centered">

                                                <div class="modal-content border-0 shadow">

                                                    <div class="modal-header"
                                                        style="background-color:#F15A24;">

                                                        <h5 class="modal-title text-white fw-bold">

                                                            Aviso

                                                        </h5>

                                                        <button type="button"
                                                                class="btn-close btn-close-white"
                                                                data-bs-dismiss="modal">
                                                        </button>

                                                    </div>

                                                    <div class="modal-body">

                                                        Deseja realmente excluir o usuário
                                                        <strong>@item.Nome</strong>?

                                                    </div>

                                                    <div class="modal-footer">

                                                        <button type="button"
                                                                class="btn btn-secondary"
                                                                data-bs-dismiss="modal">

                                                            Cancelar

                                                        </button>

                                                        <a href="/Usuarios/Delete/@item.Id"
                                                        class="btn btn-danger">

                                                            Excluir

                                                        </a>

                                                    </div>

                                                </div>

                                            </div>

                                        </div>
                                    }

                                </tbody>

                            </table>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        const pesquisa =
            document.getElementById("pesquisa");

        const filtroTipo =
            document.getElementById("filtroTipo");

        pesquisa.addEventListener("keyup", filtrar);

        // SÓ ADICIONA EVENTO SE EXISTIR
        if(filtroTipo)
        {
            filtroTipo.addEventListener("change", filtrar);
        }

        function filtrar()
        {
            let texto =
                pesquisa.value
                .trim()
                .toLowerCase();

            let tipoSelecionado = "";

            // SÓ PEGA VALOR SE EXISTIR
            if(filtroTipo)
            {
                tipoSelecionado =
                    filtroTipo.value
                    .trim()
                    .toLowerCase();
            }

            let linhas =
                document.querySelectorAll(
                    "#tabelaUsuarios tbody tr");

            linhas.forEach(linha =>
            {
                let nome =
                    linha.children[1]
                    .innerText
                    .trim()
                    .toLowerCase();

                let email =
                    linha.children[2]
                    .innerText
                    .trim()
                    .toLowerCase();

                let tipoLinha =
                    linha.children[3]
                    .innerText
                    .trim()
                    .toLowerCase();

                // PESQUISA
                let pesquisaOk =
                    nome.includes(texto)
                    || email.includes(texto);

                // FILTRO
                let filtroOk =
                    tipoSelecionado === ""
                    || tipoLinha.includes(tipoSelecionado);

                linha.style.display =
                    (pesquisaOk && filtroOk)
                    ? ""
                    : "none";
            });
        }

    </script>

</body>

</html>