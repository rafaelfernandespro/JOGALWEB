@using Microsoft.AspNetCore.Http;

@{
    Layout = null;
}

@model inter.Models.Pessoas

<!DOCTYPE html>
<html>

<head>

    <title>Novo Usuário</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
        style="background-color:#F15A24;">

        <div class="container-fluid">

            <a class="navbar-brand" href="/Dashboard">

                <img src="/logo/logo.jpg"
                    height="50"
                    class="rounded-4">

            </a> 

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid p-0">

    <div class="row g-0 align-items-stretch">

        <!-- SIDEBAR -->
        <div class="col-2 p-0">

            <div class="bg-dark text-white min-vh-100 h-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">
                        MENU
                    </h4>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                <div class="card border-0 shadow">

                    <div class="card-body p-4">

                        <h2 class="fw-bold mb-4">
                            Novo Usuário
                        </h2>

                        @if(ViewBag.Erro != null)
                        {
                            <div class="alert alert-danger">

                                @ViewBag.Erro

                            </div>
                        }

                        <form method="post">

                            <div class="mb-3">

                                <label class="form-label">
                                    Nome
                                </label>

                                <input type="text"
                                       name="Nome"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    CPF
                                </label>

                                <input type="text"
                                        name="Cpf"
                                        class="form-control"
                                        maxlength="11"
                                        minlength="11"
                                        pattern="[0-9]{11}"
                                        oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                                        required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Endereço
                                </label>

                                <input type="text"
                                       name="Endereco"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Número
                                </label>

                                <input type="text"
                                       name="Numero"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Email
                                </label>

                                <input type="email"
                                       name="Email"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Senha
                                </label>

                                <input type="password"
                                       name="Senha"
                                       class="form-control"
                                       required>

                            </div>

                            <div class="mb-4">

                                <label class="form-label">
                                    Tipo
                                </label>

                                <select name="Tipo"
                                        class="form-select">

                                    <option value="1">
                                        CLIENTE
                                    </option>

                                    @if(Context.Session.GetString("tipo") == "2")
                                    {
                                        <option value="2">
                                            OPERADOR
                                        </option>

                                        <option value="3">
                                            FUNCIONARIO
                                        </option>
                                    }

                                </select>

                            </div>

                            <button type="submit"
                                    class="btn text-white fw-bold"
                                    style="background-color:#F15A24;">

                                Salvar Usuário

                            </button>

                            <a href="/Usuarios"
                               class="btn btn-secondary">

                                Voltar

                            </a>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>