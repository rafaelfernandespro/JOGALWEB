@using Microsoft.AspNetCore.Http;

@{
    Layout = null;
}

@model List<inter.Models.Pedidos>

<!DOCTYPE html>
<html>

<head>

    <title>Meus Pedidos</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <style>

        .pedido-card
        {
            border-radius: 18px;
            transition: 0.2s;
        }

        .pedido-card:hover
        {
            transform: translateY(-3px);
        }

        .status-badge
        {
            font-size: 14px;
            padding: 8px 14px;
            border-radius: 30px;
        }

    </style>

</head>

<body class="bg-light">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
         style="background-color:#F15A24;">

        <div class="container-fluid">

            <a class="navbar-brand" href="/Catalogo">

                <img src="/logo/logo.jpg"
                    height="50"
                    class="rounded-4">

            </a>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>


                <a href="/Login"
                   class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h1 class="fw-bold">
                    Meus Pedidos
                </h1>

                <p class="text-muted">
                    Histórico de compras
                </p>
                <div class="d-flex gap-3 flex-wrap mt-3">

                    <div class="bg-white shadow-sm rounded-4 px-4 py-3">

                        <span class="text-muted d-block">

                            Total de Pedidos

                        </span>

                        <strong class="fs-4">

                            @Model.Count()

                        </strong>

                    </div>

                    <div class="bg-warning bg-opacity-25 shadow-sm rounded-4 px-4 py-3">

                        <span class="text-muted d-block">

                            Pendentes

                        </span>

                        <strong class="fs-4">

                            @Model.Count(p => p.StatusId == 1)

                        </strong>

                    </div>

                    <div class="bg-success bg-opacity-25 shadow-sm rounded-4 px-4 py-3">

                        <span class="text-muted d-block">

                            Entregues

                        </span>

                        <strong class="fs-4">

                            @Model.Count(p => p.StatusId == 4)

                        </strong>

                    </div>

                    <div class="bg-danger bg-opacity-25 shadow-sm rounded-4 px-4 py-3">

                        <span class="text-muted d-block">

                            Cancelados

                        </span>

                        <strong class="fs-4">

                            @Model.Count(p => p.StatusId == 5)

                        </strong>

                    </div>

                </div>

            </div>

        </div>

        @if(TempData["PedidoCancelado"] != null)
        {
            <div class="toast-container position-fixed top-0 end-0 p-3"
                style="z-index:9999;">

                <div id="toastCancelado"
                    class="toast align-items-center text-bg-success border-0 show"
                    role="alert">

                    <div class="d-flex">

                        <div class="toast-body fw-semibold">

                            Pedido cancelado com sucesso!

                        </div>

                        <button type="button"
                                class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast">
                        </button>

                    </div>

                </div>

            </div>

            <script>

                setTimeout(() =>
                {
                    const toast =
                        document.getElementById(
                            "toastCancelado");

                    if(toast)
                    {
                        toast.classList.remove("show");
                    }

                }, 5000);

            </script>
        }

        @if(TempData["Erro"] != null)
        {
            <div class="toast-container position-fixed top-0 end-0 p-3"
                style="z-index:9999;">

                <div id="toastErro"
                    class="toast align-items-center text-bg-danger border-0 show"
                    role="alert">

                    <div class="d-flex">

                        <div class="toast-body fw-semibold">

                            @TempData["Erro"]

                        </div>

                        <button type="button"
                                class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast">
                        </button>

                    </div>

                </div>

            </div>

            <script>

                setTimeout(() =>
                {
                    const toast =
                        document.getElementById(
                            "toastErro");

                    if(toast)
                    {
                        toast.classList.remove("show");
                    }

                }, 5000);

            </script>
        }

        <div class="card border-0 shadow mb-4">

            <div class="card-body">

                <div class="row">

                    <div class="col-md-4">

                        <select id="filtroStatus"
                                class="form-select">

                            <option value="">
                                Todos os status
                            </option>

                            <option value="pendente">
                                Pendente
                            </option>

                            <option value="preparando">
                                Preparando
                            </option>

                            <option value="entregue">
                                Entregue
                            </option>

                            <option value="cancelado">
                                Cancelado
                            </option>

                        </select>

                    </div>

                </div>

            </div>

        </div>

        @if(!Model.Any())
        {
            <div class="alert alert-warning text-center">

                Você ainda não realizou pedidos.

            </div>
        }
        else
        {
            <div class="row">

                @foreach(var pedido in Model)
                {
                    string corStatus = pedido.StatusId switch
                    {
                        1 => "bg-warning text-dark",
                        2 => "bg-info text-dark",
                        3 => "bg-primary",
                        4 => "bg-success",
                        5 => "bg-danger",
                        _ => "bg-secondary"
                    };

                    <div class="col-md-6 mb-4 pedido-card-item">

                        <div class="card pedido-card border-0 shadow h-100">

                            <div class="card-body p-4">

                                <div class="d-flex justify-content-between align-items-start mb-3">

                                    <div>

                                        <h4 class="fw-bold mb-1">

                                            Pedido #@pedido.Id

                                        </h4>

                                        <span class="text-muted">

                                            @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")

                                        </span>

                                    </div>

                                    <span class="badge status-badge status-pedido @corStatus">

                                        @pedido.Status?.Descricao

                                    </span>

                                </div>

                                <hr />

                                <div class="d-flex justify-content-between mb-3">

                                    <span class="text-muted">

                                        Total do pedido

                                    </span>

                                    <strong class="fs-5"
                                            style="color:#F15A24;">

                                        R$ @pedido.Total

                                    </strong>

                                </div>

                                <div class="d-flex gap-2">

                                    <a href="/Historico/Detalhes/@pedido.Id"
                                       class="btn btn-outline-dark flex-fill">

                                        Ver Detalhes

                                    </a>

                                    @if(pedido.StatusId == 1)
                                    {
                                        <button class="btn btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#cancelar_@pedido.Id">

                                            Cancelar

                                        </button>
                                    }

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- MODAL -->
                    <div class="modal fade"
                         id="cancelar_@pedido.Id"
                         tabindex="-1">

                        <div class="modal-dialog modal-dialog-centered">

                            <div class="modal-content border-0 shadow">

                                <div class="modal-header"
                                     style="background-color:#F15A24;">

                                    <h5 class="modal-title text-white fw-bold">

                                        Cancelar Pedido

                                    </h5>

                                    <button type="button"
                                            class="btn-close btn-close-white"
                                            data-bs-dismiss="modal">
                                    </button>

                                </div>

                                <div class="modal-body">

                                    Deseja realmente cancelar o pedido
                                    <strong>#@pedido.Id</strong>?

                                </div>

                                <div class="modal-footer">

                                    <button class="btn btn-secondary"
                                            data-bs-dismiss="modal">

                                        Voltar

                                    </button>

                                    <a href="/Historico/Cancelar/@pedido.Id"
                                       class="btn btn-danger">

                                        Cancelar Pedido

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        <div class="position-fixed bottom-0 start-0 m-4"
            style="z-index:999;">

            <a href="/Catalogo"
            class="btn btn-dark fw-bold px-4 py-2 shadow rounded-pill">

                ← Voltar

            </a>

        </div>
    </div>

    <script>

        document.addEventListener("DOMContentLoaded", () =>
        {
            const filtro =
                document.getElementById("filtroStatus");

            filtro.addEventListener("change", filtrar);

            function filtrar()
            {
                let statusSelecionado =
                    filtro.value
                    .trim()
                    .toLowerCase();

                let pedidos =
                    document.querySelectorAll(".pedido-card-item");

                pedidos.forEach(card =>
                {
                    let status =
                        card.querySelector(".status-pedido")
                        ?.textContent
                        .trim()
                        .toLowerCase();

                    let mostrar =
                        statusSelecionado === ""
                        || status === statusSelecionado;

                    card.style.display =
                        mostrar
                        ? ""
                        : "none";
                });
            }
        });

        </script>


</body>

</html>