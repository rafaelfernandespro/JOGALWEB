@using Microsoft.AspNetCore.Http;
@using inter.Helpers;
@using inter.Models;

@model IEnumerable<inter.Models.Produtos>

@{
    Layout = null;

    var carrinho =
        Context.Session
        .GetObjectFromJson<List<CarrinhoItem>>("Carrinho")
        ?? new List<CarrinhoItem>();

    int totalItens =
        carrinho.Sum(i => i.Quantidade);

    decimal totalCarrinho =
        carrinho.Sum(i => i.Preco * i.Quantidade);
}

<!DOCTYPE html>
<html>

<head>

    <title>Catalogo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        .produto-card
        {
            transition: 0.3s;
            border-radius: 20px;
            overflow: hidden;
        }

        .produto-card:hover
        {
            transform: translateY(-5px);
        }

        .produto-img
        {
            height: 240px;
            object-fit: cover;
        }

        .btn-carrinho
        {
            width: 45px;
            height: 45px;

            border-radius: 50%;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 20px;

            background-color: #F15A24;
            color: white;

            border: none;
        }

        .btn-carrinho:hover
        {
            background-color: #d94d1f;
        }

        .quantidade-btn
        {
            width: 40px;
            height: 40px;
        }

    </style>

</head>

<body class="bg-light">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

        @if(TempData["PedidoSucesso"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">

            <div id="toastPedido"
                class="toast align-items-center text-bg-success border-0 show"
                role="alert">

                <div class="d-flex">

                    <div class="toast-body fw-semibold">

                        Pedido realizado com sucesso!

                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast">
                    </button>

                </div>

            </div>

        </div>

        <script>

            setTimeout(() =>
            {
                const toast =
                    document.getElementById("toastPedido");

                if(toast)
                {
                    toast.classList.remove("show");
                }

            }, 10000);

        </script>
    }

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
         style="background-color:#F15A24;">

        <div class="container-fluid">

            <span class="navbar-brand fw-bold fs-3">
                JOGAL
            </span>

            <a href="/Historico"
            class="btn btn-light fw-bold me-2">

                Meus Pedidos

            </a>

            <div class="d-flex align-items-center">

                <!-- CARRINHO -->
                <button class="btn btn-light position-relative me-4"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#carrinhoCanvas">

                    <i class="bi bi-cart3 fs-5"></i>

                    @if(totalItens > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                            @totalItens

                        </span>
                    }

                </button>

                <!-- USUÁRIO -->
                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                   class="btn btn-light fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    @if(TempData["Sucesso"] != null)
    {
        <div class="container mt-4">

            <div class="alert alert-success">

                @TempData["Sucesso"]

            </div>

        </div>
    }

    @if(TempData["Erro"] != null)
    {
        <div class="container mt-3">

            <div class="alert alert-danger">

                @TempData["Erro"]

            </div>

        </div>
    }

    <!-- CONTEÚDO -->
    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold">
                    Catálogo
                </h1>

                <p class="text-muted">
                    Produtos disponíveis
                </p>

            </div>

        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-warning text-center">

                Sem produtos disponíveis.

            </div>
        }
        else
        {
            <div class="row">

                @foreach(var produto in Model)
                {
                    <div class="col-md-3 mb-4">

                        <div class="card produto-card border-0 shadow h-100">

                            <!-- IMAGEM -->
                            @if(string.IsNullOrEmpty(produto.Imagem))
                            {
                                <img src="https://placehold.co/600x400/orange/white?text=JOGAL"
                                     class="card-img-top produto-img">
                            }
                            else
                            {
                                <img src="/uploads/@produto.Imagem"
                                     class="card-img-top produto-img">
                            }

                            <div class="card-body d-flex flex-column">

                                <h5 class="fw-bold">

                                    @produto.Nome

                                </h5>

                                <p class="text-muted mb-3">

                                    Estoque:
                                    @produto.Qtd

                                </p>

                                <div class="mt-auto">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <strong class="fs-5"
                                                style="color:#F15A24;">

                                            R$ @produto.Preco

                                        </strong>

                                        <!-- BOTÃO -->
                                        <button class="btn-carrinho"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalProduto_@produto.Id">

                                            <i class="bi bi-cart-plus"></i>

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- MODAL -->
                    <div class="modal fade"
                         id="modalProduto_@produto.Id"
                         tabindex="-1">

                        <div class="modal-dialog modal-dialog-centered">

                            <div class="modal-content border-0 shadow">

                                <div class="modal-header"
                                     style="background-color:#F15A24;">

                                    <h5 class="modal-title text-white fw-bold">

                                        Adicionar ao Carrinho

                                    </h5>

                                    <button type="button"
                                            class="btn-close btn-close-white"
                                            data-bs-dismiss="modal">
                                    </button>

                                </div>

                                <div class="modal-body text-center">

                                    <h4 class="fw-bold mb-4">

                                        @produto.Nome

                                    </h4>

                                    <div class="d-flex justify-content-center align-items-center gap-3">

                                        <button class="btn btn-outline-secondary quantidade-btn"
                                                onclick="diminuirQuantidade(@produto.Id)">

                                            -

                                        </button>

                                        <input type="number"
                                               id="quantidade_@produto.Id"
                                               value="1"
                                               min="1"
                                               class="form-control text-center"
                                               style="width:80px;">

                                        <button class="btn btn-outline-secondary quantidade-btn"
                                                onclick="aumentarQuantidade(@produto.Id)">

                                            +

                                        </button>

                                    </div>

                                </div>

                                <div class="modal-footer">

                                    <button class="btn btn-secondary"
                                            data-bs-dismiss="modal">

                                        Cancelar

                                    </button>

                                    <button class="btn text-white"
                                            style="background-color:#F15A24;"
                                            onclick="adicionarCarrinho(@produto.Id)">

                                        Adicionar

                                    </button>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

    <!-- OFFCANVAS -->
    <div class="offcanvas offcanvas-end"
         tabindex="-1"
         id="carrinhoCanvas">

        <div class="offcanvas-header">

            <h4 class="fw-bold">

                Seu Carrinho

            </h4>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="offcanvas">
            </button>

        </div>

        <div class="offcanvas-body">

            @if(!carrinho.Any())
            {
                <div class="alert alert-warning text-center">

                    Carrinho vazio.

                </div>
            }
            else
            {
                @foreach(var item in carrinho)
                {
                    <div class="card border-0 shadow-sm mb-3">

                        <div class="card-body">

                            <div class="d-flex gap-3">

                                @if(string.IsNullOrEmpty(item.Imagem))
                                {
                                    <img src="https://placehold.co/100x100"
                                         width="80"
                                         height="80"
                                         style="object-fit:cover;
                                                border-radius:12px;">
                                }
                                else
                                {
                                    <img src="/uploads/@item.Imagem"
                                         width="80"
                                         height="80"
                                         style="object-fit:cover;
                                                border-radius:12px;">
                                }

                                <div class="flex-grow-1">

                                    <h6 class="fw-bold">

                                        @item.Nome

                                    </h6>

                                    <p class="mb-2 text-muted">

                                        R$ @item.Preco

                                    </p>

                                    <div class="d-flex align-items-center gap-2">

                                        <button class="btn btn-sm btn-outline-dark"
                                                onclick="diminuir(@item.ProdutoId)">

                                            -

                                        </button>

                                        <strong>

                                            @item.Quantidade

                                        </strong>

                                        <button class="btn btn-sm btn-outline-dark"
                                                onclick="aumentar(@item.ProdutoId)">

                                            +

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                }

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold">
                        Total
                    </h5>

                    <h4 class="fw-bold"
                        style="color:#F15A24;">

                        R$ @totalCarrinho

                    </h4>

                </div>

                <form method="post"
                    action="/Carrinho/FinalizarPedido">

                    <button class="btn w-100 text-white fw-bold"
                            style="background-color:#F15A24;">

                        Finalizar Pedido

                    </button>

                </form>
            }

        </div>

    </div>

    <script>

        function aumentarQuantidade(id)
        {
            let input =
                document.getElementById("quantidade_" + id);

            input.value =
                parseInt(input.value) + 1;
        }

        function diminuirQuantidade(id)
        {
            let input =
                document.getElementById("quantidade_" + id);

            if(parseInt(input.value) > 1)
            {
                input.value =
                    parseInt(input.value) - 1;
            }
        }

        async function adicionarCarrinho(id)
        {
            let quantidade =
                document.getElementById("quantidade_" + id).value;

            await fetch("/Carrinho/Adicionar",
            {
                method: "POST",

                headers:
                {
                    "Content-Type":
                    "application/x-www-form-urlencoded"
                },

                body:
                    `produtoId=${id}&quantidade=${quantidade}`
            });

            location.reload();
        }

    </script>

    <script>

        async function aumentar(id)
        {
            await fetch(`/Carrinho/Aumentar?produtoId=${id}`,
            {
                method: "POST"
            });

            location.reload();
        }

        async function diminuir(id)
        {
            await fetch(`/Carrinho/Diminuir?produtoId=${id}`,
            {
                method: "POST"
            });

            location.reload();
        }

        async function remover(id)
        {
            await fetch(`/Carrinho/Remover?produtoId=${id}`,
            {
                method: "POST"
            });

            location.reload();
        }

        </script>

</body>

</html>