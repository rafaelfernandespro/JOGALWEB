@using Microsoft.AspNetCore.Http;
@using inter.Helpers;
@using inter.Models;

@model IEnumerable<inter.Models.Produtos>

@{
    Layout = null;

    var carrinho =
        Context.Session
        .GetObjectFromJson<List<CarrinhoItem>>("Carrinho")
        ?? new List<CarrinhoItem>();

    int totalItens =
        carrinho.Sum(i => i.Quantidade);

    decimal totalCarrinho =
        carrinho.Sum(i => i.Preco * i.Quantidade);
}

<!DOCTYPE html>
<html>

<head>

    <title>Catálogo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        .produto-card
        {
            border-radius: 18px;
            transition: 0.2s;
            overflow: hidden;
        }

        .produto-card:hover
        {
            transform: translateY(-4px);
        }

        .produto-img
        {
            height: 240px;
            width: 100%;
            object-fit: cover;
        }

        .btn-carrinho
        {
            width: 45px;
            height: 45px;

            border-radius: 50%;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 20px;

            background-color: #F15A24;
            color: white;

            border: none;
        }

        .btn-carrinho:hover
        {
            background-color: #d94d1f;
        }

        .quantidade-btn
        {
            width: 40px;
            height: 40px;
        }

        .sidebar
        {
            min-height: 100vh;
        }

    </style>

</head>

<body class="bg-light">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    @if(TempData["PedidoSucesso"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">

            <div class="toast align-items-center text-bg-success border-0 show">

                <div class="d-flex">

                    <div class="toast-body fw-semibold">

                        Pedido realizado com sucesso!

                    </div>

                    <button type="button"
                            class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast">
                    </button>

                </div>

            </div>

        </div>
    }

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
         style="background-color:#F15A24;">

        <div class="container-fluid">

            <a class="navbar-brand" href="/Dashboard">

                <img src="/logo/logo.jpg"
                    height="50"
                    class="rounded-4">

            </a> 

            <div class="d-flex align-items-center">

                <!-- CARRINHO -->
                <button class="btn btn-dark position-relative me-4"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#carrinhoCanvas">

                    <i class="bi bi-cart3 fs-5"></i>

                    <span id="badgeCarrinho"
                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger
                        @(carrinho.Count == 0 ? "d-none" : "")">

                        @carrinho.Count

                    </span>
                </button>

                <!-- USUÁRIO -->
                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                   class="btn btn-dark fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid p-0">

        <div class="row g-0 align-items-stretch">

            <!-- SIDEBAR -->
            <div class="col-2 p-0">

                <div class="bg-dark text-white min-vh-100 h-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-2">

                            <a href="/Catalogo"
                               class="nav-link text-white fs-4 fw-bold">

                                Catálogo

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Historico"
                               class="nav-link text-white fs-4">

                                Meus Pedidos

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Perfil"
                               class="nav-link text-white fs-4">

                                Meu Perfil

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                @if(TempData["Sucesso"] != null)
                {
                    <div class="alert alert-success">

                        @TempData["Sucesso"]

                    </div>
                }

                @if(TempData["Erro"] != null)
                {
                    <div class="alert alert-danger">

                        @TempData["Erro"]

                    </div>
                }

                <!-- TOPO -->
                <div class="d-flex justify-content-between align-items-center mb-5">

                    <div>

                        <h1 class="fw-bold">
                            Catálogo
                        </h1>

                        <p class="text-muted">
                            Produtos disponíveis
                        </p>

                    </div>

                    <form method="get"
                        class="card border-0 shadow-sm p-3 mb-4">

                        <div class="row g-3">

                            <div class="d-flex gap-3">

                                <!-- PESQUISA -->
                                <input type="text"
                                    id="barraPesquisa"
                                    class="form-control"
                                    placeholder="Pesquisar produto..."
                                    style="width: 420px;">

                                <!-- CATEGORIA -->
                                <select id="filtroCategoria"
                                        class="form-select"
                                        style="width: 260px;">

                                    <option value="">
                                        Todas as categorias
                                    </option>

                                    @foreach(var tipo in ViewBag.Tipos)
                                    {
                                        if(ViewBag.TipoSelecionado != null
                                            && ViewBag.TipoSelecionado == tipo.Id)
                                        {
                                            <option value="@tipo.Id" selected>

                                                @tipo.Descricao

                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@tipo.Id">

                                                @tipo.Descricao

                                            </option>
                                        }
                                    }

                                </select>

                            </div>

                        </div>

                    </form>

                </div>

                @if (!Model.Any())
                {
                    <div class="alert alert-warning text-center">

                        Sem produtos disponíveis.

                    </div>
                }
                else
                {
                    <div class="row">

                        @foreach(var produto in Model)
                        {
                            <div class="col-xl-3 col-lg-4 col-md-6 mb-4 produto-card-item"
                                data-nome="@produto.Nome.ToLower()"
                                data-tipo="@produto.TipoId">

                                <div class="card produto-card border-0 shadow h-100">

                                    <!-- IMAGEM -->
                                    @if(string.IsNullOrEmpty(produto.Imagem))
                                    {
                                        <img src="https://placehold.co/600x400/orange/white?text=JOGAL"
                                             class="produto-img">
                                    }
                                    else
                                    {
                                        <img src="/uploads/@produto.Imagem"
                                             class="produto-img">
                                    }

                                    <div class="card-body d-flex flex-column">

                                        <h5 class="fw-bold">

                                            @produto.Nome

                                        </h5>

                                        <p class="text-muted mb-3">

                                            Estoque:
                                            @produto.Qtd

                                        </p>

                                        <div class="mt-auto">

                                            <div class="d-flex justify-content-between align-items-center">

                                                <strong class="fs-5"
                                                        style="color:#F15A24;">

                                                    R$ @produto.Preco

                                                </strong>

                                                <button class="btn-carrinho"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalProduto_@produto.Id">

                                                    <i class="bi bi-cart-plus"></i>

                                                </button>

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                            <!-- MODAL -->
                            <div class="modal fade"
                                 id="modalProduto_@produto.Id"
                                 tabindex="-1">

                                <div class="modal-dialog modal-dialog-centered">

                                    <div class="modal-content border-0 shadow">

                                        <div class="modal-header"
                                             style="background-color:#F15A24;">

                                            <h5 class="modal-title text-white fw-bold">

                                                Adicionar ao Carrinho

                                            </h5>

                                            <button type="button"
                                                    class="btn-close btn-close-white"
                                                    data-bs-dismiss="modal">
                                            </button>

                                        </div>

                                        <div class="modal-body text-center">

                                            <h4 class="fw-bold mb-4">

                                                @produto.Nome

                                            </h4>

                                            <div class="d-flex justify-content-center align-items-center gap-3">

                                                <button class="btn btn-outline-secondary quantidade-btn"
                                                        onclick="diminuirQuantidade(@produto.Id)">

                                                    -

                                                </button>

                                                <input type="number"
                                                id="quantidade_@produto.Id"
                                                value="1"
                                                min="1"
                                                oninput="
                                                        this.value =
                                                        this.value.replace('-', '');
                                                        if(this.value < 1 && this.value != '')
                                                        {
                                                            this.value = 1;
                                                        }";
                                                class="form-control text-center";
                                                style="width:80px;">

                                                <button class="btn btn-outline-secondary quantidade-btn"
                                                        onclick="aumentarQuantidade(@produto.Id)">

                                                    +

                                                </button>

                                            </div>

                                        </div>

                                        <div class="modal-footer">

                                            <button class="btn btn-secondary"
                                                    data-bs-dismiss="modal">

                                                Cancelar

                                            </button>

                                            <button class="btn text-white"
                                                    style="background-color:#F15A24;"
                                                    onclick="adicionarCarrinho(@produto.Id)">

                                                Adicionar

                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </div>
                        }

                    </div>
                }

            </div>

        </div>

    </div>

    <!-- OFFCANVAS -->
    <div class="offcanvas offcanvas-end"
        tabindex="-1"
        id="carrinhoCanvas">

        <div class="offcanvas-header">

            <h4 class="fw-bold">

                Seu Carrinho

            </h4>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="offcanvas">
            </button>

        </div>

        <div class="offcanvas-body"
            id="conteudoCarrinho">

            @await Html.PartialAsync(
                "~/Views/Carrinho/_CarrinhoPartial.cshtml",
                carrinho)

        </div>

    </div>


    <script>

        function aumentarQuantidade(id)
        {
            let input =
                document.getElementById("quantidade_" + id);

            input.value =
                parseInt(input.value) + 1;
        }

        function diminuirQuantidade(id)
        {
            let input =
                document.getElementById("quantidade_" + id);

            if(parseInt(input.value) > 1)
            {
                input.value =
                    parseInt(input.value) - 1;
            }
        }

        async function atualizarCarrinho()
        {
            const resposta =
                await fetch("/Carrinho/CarrinhoPartial");

            const html =
                await resposta.text();

            document.getElementById(
                "conteudoCarrinho").innerHTML = html;

            // PEGA TODOS OS CARDS DO CARRINHO
            let cards =
                document.querySelectorAll(
                    "#conteudoCarrinho .card");

            // CONTA PRODUTOS DIFERENTES
            let total =
                cards.length;

            const badge =
                document.getElementById(
                    "badgeCarrinho");

            if(badge)
            {
                badge.innerText = total;

                if(total > 0)
                {
                    badge.classList.remove("d-none");
                }
                else
                {
                    badge.classList.add("d-none");
                }
            }
        }

        async function adicionarCarrinho(id)
        {
            let input =
                document.getElementById(
                    "quantidade_" + id);

            let quantidade =
                parseInt(input.value);

            // VALIDAÇÃO
            if(isNaN(quantidade) || quantidade < 1)
            {
                alert(
                    "Digite uma quantidade válida.");

                input.value = "";

                input.focus();

                return;
            }

            const resposta =
                await fetch("/Carrinho/Adicionar",
            {
                method: "POST",

                headers:
                {
                    "Content-Type":
                    "application/x-www-form-urlencoded"
                },

                body:
                    `produtoId=${id}&quantidade=${quantidade}`
            });

            // ERRO DO BACK-END
            if(!resposta.ok)
            {
                const erro =
                    await resposta.text();

                alert(erro);

                return;
            }

            // ATUALIZA CARRINHO
            await atualizarCarrinho();

            // RESETAR INPUT
            input.value = 1;

            // FECHAR MODAL
            const modalElemento =
                document.getElementById(
                    "modalProduto_" + id);

            const modal =
                bootstrap.Modal.getInstance(
                    modalElemento);

            if(modal)
            {
                modal.hide();
            }
        }

        async function aumentar(id)
        {
            await fetch(
                `/Carrinho/Aumentar?produtoId=${id}`,
            {
                method: "POST"
            });

            await atualizarCarrinho();
        }

        async function diminuir(id)
        {
            await fetch(
                `/Carrinho/Diminuir?produtoId=${id}`,
            {
                method: "POST"
            });

            await atualizarCarrinho();
        }

        async function remover(id)
        {
            await fetch(
                `/Carrinho/Remover?produtoId=${id}`,
            {
                method: "POST"
            });

            await atualizarCarrinho();
        }

        async function limparCarrinho()
        {
            await fetch("/Carrinho/Limpar",
            {
                method: "POST"
            });

            await atualizarCarrinho();

            // FECHAR MODAL
            const modalElemento =
                document.getElementById(
                    "modalLimparCarrinho");

            const modal =
                bootstrap.Modal.getInstance(
                    modalElemento);

            if(modal)
            {
                modal.hide();
            }
        }

        document.addEventListener(
            "DOMContentLoaded",
            atualizarCarrinho);


        document.addEventListener("DOMContentLoaded", () =>
        {
            atualizarCarrinho();

            const barraPesquisa =
                document.getElementById(
                    "barraPesquisa");

            const filtroCategoria =
                document.getElementById(
                    "filtroCategoria");

            barraPesquisa.addEventListener(
                "input",
                filtrar);

            filtroCategoria.addEventListener(
                "change",
                filtrar);

            function filtrar()
            {
                let texto =
                    barraPesquisa.value
                    .trim()
                    .toLowerCase();

                let categoria =
                    filtroCategoria.value;

                let produtos =
                    document.querySelectorAll(
                        ".produto-card-item");

                produtos.forEach(produto =>
                {
                    let nome =
                        produto.dataset.nome;

                    let tipo =
                        produto.dataset.tipo;

                    let mostrar =
                        nome.includes(texto)
                        &&
                        (
                            categoria === ""
                            || tipo === categoria
                        );

                    produto.style.display =
                        mostrar
                        ? ""
                        : "none";
                });
            }
        });

    </script>

     <!-- MODAL LIMPAR CARRINHO -->
    <div class="modal fade"
        id="modalLimparCarrinho"
        tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content border-0 shadow">

                <div class="modal-header"
                    style="background-color:#F15A24;">

                    <h5 class="modal-title text-white fw-bold">

                        Confirmar Limpeza

                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body">

                    Deseja realmente limpar o carrinho?

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Cancelar

                    </button>

                    <button type="button"
                            class="btn btn-danger"
                            onclick="limparCarrinho()">

                        Limpar

                    </button>

                </div>

            </div>

        </div>

    </div>

</body>

</html>