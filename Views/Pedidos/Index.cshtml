@using Microsoft.AspNetCore.Http;

@{
    Layout = null;
}

@model List<inter.Models.Pedidos>

<!DOCTYPE html>
<html>

<head>

    <title>Pedidos</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-dark shadow"
         style="background-color:#F15A24;">

        <div class="container-fluid">

            <a class="navbar-brand" href="/Dashboard">

                <img src="/logo/logo.jpg"
                    height="50"
                    class="rounded-4">

            </a>

            <div class="d-flex align-items-center me-4">

                <span class="text-white fw-semibold me-3">

                    Olá,
                    @Context.Session.GetString("usuario")

                </span>

                <a href="/Login"
                   class="btn btn-dark fw-bold">

                    Sair

                </a>

            </div>

        </div>

    </nav>

    <div class="container-fluid p-0">

        <div class="row g-0 align-items-stretch">

            <!-- SIDEBAR -->
            <div class="col-2 p-0">

                <div class="bg-dark text-white min-vh-100 h-100 p-3">

                    <h4 class="fw-bold mb-4"
                        style="color:#F7931E;">

                        MENU

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-2">

                            <a href="/Dashboard"
                               class="nav-link text-white fs-4">

                                Dashboard

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Produtos"
                               class="nav-link text-white fs-4">

                                Estoque

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Pedidos"
                               class="nav-link text-white fs-4 fw-bold">

                                Pedidos

                            </a>

                        </li>

                        <li class="nav-item mb-2">

                            <a href="/Usuarios"
                               class="nav-link text-white fs-4">

                                Usuários

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- CONTEÚDO -->
            <div class="col-10 p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <div>

                        <h1 class="fw-bold">
                            Pedidos
                        </h1>

                        <p class="text-muted">
                            Gerenciamento de pedidos
                        </p>

                    </div>

                </div>

                <!--FILTROS-->

                <div class="card border-0 shadow mb-4">

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- ID -->
                            <div class="col-md-2">

                                <label class="form-label fw-semibold">
                                    ID Pedido
                                </label>

                                <input type="number"
                                    id="filtroId"
                                    class="form-control"
                                    placeholder="Ex: 1024"
                                    min="1"
                                    oninput="this.value =
                                        this.value.replace('-', '')">

                            </div>

                            <!-- STATUS -->
                            <div class="col-md-2">

                                <label class="form-label fw-semibold">
                                    Status
                                </label>

                                <select id="filtroStatus"
                                        class="form-select">

                                    <option value="">
                                        Todos
                                    </option>

                                    @foreach(var status in ViewBag.Status)
                                    {
                                        <option value="@status.Descricao">

                                            @status.Descricao

                                        </option>
                                    }

                                </select>

                            </div>

                            <!-- DATA PEDIDO -->
                            <div class="col-md-3">

                                <label class="form-label fw-semibold">
                                    Pedido de
                                </label>

                                <input type="date"
                                    id="dataPedidoInicio"
                                    class="form-control"
                                    max="9999-12-31">

                            </div>

                            <div class="col-md-3">

                                <label class="form-label fw-semibold">
                                    Pedido até
                                </label>

                                <input type="date"
                                    id="dataPedidoFim"
                                    class="form-control"
                                    max="9999-12-31">

                            </div>

                            <!-- DATA FINAL -->
                            <div class="col-md-3">

                                <label class="form-label fw-semibold">
                                    Finalizado de
                                </label>

                                <input type="date"
                                    id="dataFinalInicio"
                                    class="form-control"
                                    max="9999-12-31">

                            </div>

                            <div class="col-md-3">

                                <label class="form-label fw-semibold">
                                    Finalizado até
                                </label>

                                <input type="date"
                                    id="dataFinalFim"
                                    class="form-control"
                                    max="9999-12-31">

                            </div>

                        </div>

                    </div>

                </div>

                <div class="card border-0 shadow">

                    <div class="card-body">

                        <table class="table table-hover align-middle">

                            <thead>

                                
                                <tr>
                                    <th>ID</th>
                                    <th>Cliente</th>
                                    <th>Data</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Finalizado</th>
                                    <th>Ações</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach(var pedido in Model)
                                {
                                    string corStatus = pedido.StatusId switch
                                    {
                                        1 => "bg-warning text-dark",
                                        2 => "bg-info text-dark",
                                        3 => "bg-primary",
                                        4 => "bg-success",
                                        5 => "bg-danger",
                                        _ => "bg-secondary"
                                    };

                                    <tr
                                        data-id="@pedido.Id"
                                        data-status="@pedido.Status?.Descricao"
                                        data-pedido="@pedido.DataPedido.ToString("yyyy-MM-dd")"
                                        data-final="@(pedido.DataFinal?.ToString("yyyy-MM-dd") ?? "")">

                                        <td>
                                            #@pedido.Id
                                        </td>

                                        <td>
                                            @pedido.ClienteId
                                        </td>

                                        <td>
                                            @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")
                                        </td>

                                        <td class="fw-bold"
                                            style="color:#F15A24;">

                                            R$ @pedido.Total

                                        </td>


                                        <td>

                                            <span class="badge @corStatus">

                                                @pedido.Status?.Descricao

                                            </span>

                                        </td>

                                        <td>

                                            @if(pedido.DataFinal != null)
                                            {
                                                <span class="fw-semibold text-success">

                                                    @pedido.DataFinal?.ToString("dd/MM/yyyy HH:mm")

                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">

                                                    Em andamento

                                                </span>
                                            }

                                        </td>

                                        <td>

                                            <a href="/Pedidos/Detalhes/@pedido.Id"
                                               class="btn btn-dark btn-sm fw-bold">

                                                Detalhes

                                            </a>

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        document.addEventListener("DOMContentLoaded", () =>
        {
            const filtroId =
                document.getElementById("filtroId");

            const filtroStatus =
                document.getElementById("filtroStatus");

            const dataPedidoInicio =
                document.getElementById("dataPedidoInicio");

            const dataPedidoFim =
                document.getElementById("dataPedidoFim");

            const dataFinalInicio =
                document.getElementById("dataFinalInicio");

            const dataFinalFim =
                document.getElementById("dataFinalFim");

            const linhas =
                document.querySelectorAll("tbody tr");

            [
                filtroId,
                filtroStatus,
                dataPedidoInicio,
                dataPedidoFim,
                dataFinalInicio,
                dataFinalFim
            ].forEach(campo =>
            {
                campo.addEventListener("input", filtrar);
                campo.addEventListener("change", filtrar);
            });

            function filtrar()
            {
                linhas.forEach(linha =>
                {
                    const id =
                        linha.dataset.id;

                    const status =
                        linha.dataset.status?.toLowerCase();

                    const dataPedido =
                        linha.dataset.pedido;

                    const dataFinal =
                        linha.dataset.final;

                    let mostrar = true;

                    // ID
                    if(filtroId.value &&
                        !id.includes(filtroId.value))
                    {
                        mostrar = false;
                    }

                    // STATUS
                    if(filtroStatus.value &&
                        status !== filtroStatus.value.toLowerCase())
                    {
                        mostrar = false;
                    }

                    // DATA PEDIDO INICIO
                    if(dataPedidoInicio.value &&
                        dataPedido < dataPedidoInicio.value)
                    {
                        mostrar = false;
                    }

                    // DATA PEDIDO FIM
                    if(dataPedidoFim.value &&
                        dataPedido > dataPedidoFim.value)
                    {
                        mostrar = false;
                    }

                    // DATA FINAL INICIO
                    if(dataFinalInicio.value)
                    {
                        if(!dataFinal ||
                            dataFinal < dataFinalInicio.value)
                        {
                            mostrar = false;
                        }
                    }

                    // DATA FINAL FIM
                    if(dataFinalFim.value)
                    {
                        if(!dataFinal ||
                            dataFinal > dataFinalFim.value)
                        {
                            mostrar = false;
                        }
                    }

                    linha.style.display =
                        mostrar ? "" : "none";
                });
            }
        });

    </script>

</body>

</html>